<!DOCTYPE html><html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Desenho de Calha</title>
<style>
body { font-family: Arial; margin: 10px; background:#f5f5f5; }
.container { display:flex; gap:15px; align-items:flex-start; }
.inputs, .info { background:white; padding:10px; border-radius:8px; max-height:500px; overflow-y:auto; }
.inputs { width:260px; }
.info { width:240px; }
canvas { background:white; border-radius:8px; cursor: grab; width:100%; height:300px; flex-shrink:0; }
.segmento { margin-top:10px; border-top:1px solid #ddd; padding-top:8px; cursor:pointer; }
.segmento.ativo { background:#e6f0ff; border:1px solid #4a90e2; border-radius:6px; }
.linha { display:flex; gap:5px; margin-top:5px; }
.linha label { min-width:70px; font-size:12px; }
.linha input { flex:1; }
button { margin-top:8px; width:100%; padding:6px; }
.item { cursor:pointer; padding:3px; font-size:13px; }
.item.ativo { background:#d0e6ff; }
@media (min-width: 900px){ canvas{height:500px;} }
@media (orientation: portrait){ .container{flex-direction:column;} canvas{order:-1;} }
</style>
</head>
<body><h3>Desenhador de Calha</h3><div class="container"><div class="inputs" id="inputs">
<label>Unidade</label>
<select id="unidade"><option value="mm">mm</option><option value="cm">cm</option></select><label>Escala</label> <input type="range" id="escala" min="0.2" max="5" step="0.05" value="1" oninput="atualizarEscala()">

<div id="escalaValor">100%</div><div class="segmento" onclick="ativarSegmento(this)">
<strong>Dobra 1</strong>
<div class="linha"><label>Largura</label><input type="number" class="largura" value="100"></div>
<div class="linha"><label>Ângulo</label><input type="number" class="angulo" value="45"></div>
<button onclick="removerSegmento(event,this)">Remover</button>
</div><button onclick="adicionarSegmento()">+ Dobra</button> <button onclick="desenhar()">Desenhar</button> <button onclick="exportarImagem()">Imagem</button> <button onclick="window.print()">PDF</button>

</div><canvas id="canvas"></canvas>

<div class="info">
<h4>Dobras</h4>
<div id="lista"></div>
</div></div><script>
let panX=0,panY=0,isDragging=false,startX,startY;
let segmentoAtivo=null;
let escalaZoom = 1;
let lastDistance = null;

const canvas=document.getElementById('canvas');
const ctx=canvas.getContext('2d');

function ajustarCanvas(){
 const rect = canvas.getBoundingClientRect();
 canvas.width = rect.width;
 canvas.height = rect.height;
}

window.addEventListener('resize', ()=>{ajustarCanvas();desenhar();});

// mouse
canvas.onmousedown=e=>{isDragging=true;startX=e.offsetX-panX;startY=e.offsetY-panY;}
canvas.onmousemove=e=>{if(!isDragging)return;panX=e.offsetX-startX;panY=e.offsetY-startY;desenhar();}
canvas.onmouseup=()=>{isDragging=false;}
canvas.onmouseleave=()=>{isDragging=false;}

// duplo clique centralizar
canvas.ondblclick=()=>{
 panX=0; panY=0;
 desenhar();
}

// touch pan + pinch
canvas.addEventListener('touchstart', (e)=>{
 if(e.touches.length===1){
   isDragging=true;
   const t=e.touches[0];
   const rect=canvas.getBoundingClientRect();
   startX=t.clientX-rect.left-panX;
   startY=t.clientY-rect.top-panY;
 }
 if(e.touches.length===2){
   lastDistance = getDistance(e.touches);
 }
});

canvas.addEventListener('touchmove', (e)=>{
 if(e.touches.length===1 && isDragging){
   const t=e.touches[0];
   const rect=canvas.getBoundingClientRect();
   panX=t.clientX-rect.left-startX;
   panY=t.clientY-rect.top-startY;
 }
 if(e.touches.length===2){
   const dist = getDistance(e.touches);
   if(lastDistance){
     escalaZoom *= dist/lastDistance;
   }
   lastDistance = dist;
 }
 desenhar();
 e.preventDefault();
},{passive:false});

canvas.addEventListener('touchend', ()=>{
 isDragging=false;
 lastDistance=null;
});

function getDistance(touches){
 const dx=touches[0].clientX - touches[1].clientX;
 const dy=touches[0].clientY - touches[1].clientY;
 return Math.sqrt(dx*dx+dy*dy);
}

function ativarSegmento(el){
 document.querySelectorAll('.segmento').forEach(s=>s.classList.remove('ativo'));
 el.classList.add('ativo');
}

function removerSegmento(e,btn){ e.stopPropagation(); btn.parentElement.remove(); desenhar(); }

function adicionarSegmento(){
 const container=document.getElementById('inputs');
 const numero=container.querySelectorAll('.segmento').length+1;
 const div=document.createElement('div');
 div.className='segmento';
 div.setAttribute('onclick','ativarSegmento(this)');
 div.innerHTML=`
 <strong>Dobra ${numero}</strong>
 <div class="linha"><label>Largura</label><input type="number" class="largura" value="100"></div>
 <div class="linha"><label>Ângulo</label><input type="number" class="angulo" value="45"></div>
 <button onclick="removerSegmento(event,this)">Remover</button>
 `;
 container.insertBefore(div, container.children[container.children.length-4]);
}

function atualizarEscala(){
 const e=parseFloat(document.getElementById('escala').value);
 document.getElementById('escalaValor').innerText=Math.round(e*100)+"%";
 desenhar();
}

function desenhar(){
 ajustarCanvas();

 const unidade=document.getElementById('unidade').value;
 const fator=unidade==='cm'?10:1;
 const escala=parseFloat(document.getElementById('escala').value)*escalaZoom;

 const larguras=document.querySelectorAll('.largura');
 const angulos=document.querySelectorAll('.angulo');
 const lista=document.getElementById('lista');
 lista.innerHTML='';

 ctx.clearRect(0,0,canvas.width,canvas.height);
 ctx.save();
 ctx.translate(panX,panY);

 let pontos=[];
 let x=50,y=canvas.height/2;
 let anguloAtual=0;

 pontos.push({x,y});

 for(let i=0;i<larguras.length;i++){
   const L=parseFloat(larguras[i].value)*fator;
   const ang=parseFloat(angulos[i].value)*Math.PI/180;

   anguloAtual+=ang;

   const dx=Math.cos(anguloAtual)*L*escala;
   const dy=-Math.sin(anguloAtual)*L*escala;

   x+=dx; y+=dy;
   pontos.push({x,y});
 }

 ctx.beginPath();
 ctx.moveTo(pontos[0].x,pontos[0].y);

 for(let i=1;i<pontos.length;i++){
   ctx.lineWidth=(segmentoAtivo===i-1)?3:1;
   ctx.strokeStyle=(segmentoAtivo===i-1)?'#007bff':'black';
   ctx.lineTo(pontos[i].x,pontos[i].y);
 }
 ctx.stroke();

 for(let i=0;i<larguras.length;i++){
   const p=pontos[i+1];
   ctx.fillText(`s${i+1}`,p.x-10,p.y-5);

   const L=larguras[i].value;
   const ang=angulos[i].value;
   const interno=180-(parseFloat(ang)||0);

   const item=document.createElement('div');
   item.className='item';
   item.innerHTML=`s${i+1} | L:${L} | D:${ang}° | I:${interno}°`;
   item.onclick=()=>{segmentoAtivo=i;desenhar();destacarItem(item);};
   lista.appendChild(item);
 }

 ctx.restore();
}

function destacarItem(el){
 document.querySelectorAll('.item').forEach(i=>i.classList.remove('ativo'));
 el.classList.add('ativo');
}

function exportarImagem(){
 const link=document.createElement('a');
 link.download='calha.png';
 link.href=canvas.toDataURL();
 link.click();
}

window.onload=()=>{ajustarCanvas();atualizarEscala();};
</script></body>
</html>
